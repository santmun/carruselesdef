# Kie AI API Key (REQUERIDO)
# 1. Crea una cuenta en https://kie.ai/
# 2. Ve a tu perfil/settings y copia tu API key
# 3. Renombra este archivo a .env y pega tu key abajo
KIE_AI_API_KEY=tu-api-key-aqui

# Google Drive (OPCIONAL) - Si quieres copiar los carruseles automaticamente
# GOOGLE_DRIVE_CAROUSEL_PATH=/Users/tu-usuario/Library/CloudStorage/GoogleDrive-.../Mi unidad/CAROUSEL
